{
  "headers": [
    { "source": "**/*.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "**/*.css", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "**/*.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "sw.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "manifest.json", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "**/*.png", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
